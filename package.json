{
  "name": "agijobmanager",
  "version": "0.1.0",
  "private": true,
  "description": "Prime-first AGI job settlement and procurement protocol",
  "scripts": {
    "build": "npx truffle compile",
    "size": "node scripts/check-bytecode-size.js",
    "check:no-binaries": "node scripts/check-no-binaries.mjs",
    "docs:gen": "node scripts/docs/gen-docs.mjs",
    "docs:check": "node scripts/docs/check-docs.mjs",
    "docs:ens:gen": "node scripts/docs/generate-ens-reference.mjs",
    "docs:ens:check": "node scripts/docs/check-ens-docs.mjs",
    "docs:interface": "node scripts/generate-interface-doc.js",
    "ens:phase0:mainnet": "node scripts/ens/phase0-mainnet-snapshot.mjs",
    "lint": "solhint \"contracts/**/*.sol\"",
    "test": "npx truffle compile --all && npx truffle test --network test && node test/AGIJobManager.test.js && node scripts/check-contract-sizes.js",
    "test:ui": "node scripts/ui/run_ui_smoke_test.js",
    "ui:abi": "node scripts/ui/export_abi.js",
    "ui:abi:check": "node scripts/ui/check_ui_abi.js",
    "merkle:proof": "node scripts/merkle/generate_merkle_proof.js",
    "merkle:export": "node scripts/merkle/export_merkle_proofs.js",
    "etherscan:prep": "node scripts/etherscan/prepare_inputs.js",
    "advisor:job": "node scripts/advisor/state_advisor.js",
    "forge:build": "PATH=\"$HOME/.foundry/bin:$PATH\" forge build",
    "forge:test": "PATH=\"$HOME/.foundry/bin:$PATH\" forge test",
    "forge:invariant": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=ci forge test --match-path \"forge-test/invariant/*.t.sol\"",
    "slither": "./scripts/security/run-slither.sh",
    "deploy:agijobmanager:prod": "AGIJOBMANAGER_DEPLOY=1 npx truffle migrate --f 6 --to 6",
    "test:prime": "npm run test:prime:unit && npm run forge:fuzz && npm run forge:invariant",
    "test:prime:ci": "npm run forge:fuzz:ci && npm run forge:fuzz:manager && npm run forge:invariant:all && npm run forge:invariant:clock && npm run test:prime:unit && npm run test:size && npm run test:prime:deploy-smoke",
    "test:size": "cd hardhat && npm run compile && cd .. && node scripts/check-bytecode-size.js",
    "test:prime:deploy-smoke": "cd hardhat && npm run compile && npm run deploy:prime:smoke",
    "deploy:prime:dry-run:mainnet": "cd hardhat && npm run deploy:prime:dry-run:mainnet",
    "deploy:prime:mainnet": "cd hardhat && npm run deploy:prime:mainnet",
    "deploy:prime:sepolia": "cd hardhat && npm run deploy:prime:sepolia",
    "test:prime:unit": "npx truffle test --network test test/prime.discovery-settlement.test.js test/prime.discovery.pause-clock.test.js test/prime.ownership-pause.mainnet.test.js test/prime.manager.pause-clock.test.js",
    "test:size:benchmark": "node scripts/benchmark-prime-bytecode.js",
    "forge:fuzz": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=default forge test --match-path \"forge-test/fuzz/*.t.sol\"",
    "forge:soak": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=soak forge test --match-path \"forge-test/invariant/*.t.sol\"",
    "test:prime:security": "npm run forge:fuzz:ci && npm run forge:fuzz:manager && npm run forge:invariant:all && npm run forge:invariant:clock && npm run forge:soak",
    "forge:invariant:prime": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=ci forge test --match-contract PrimeProtocolInvariants",
    "forge:invariant:ghost": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=ci forge test --match-contract PrimeProtocolGhostInvariants",
    "test:prime:audit": "npm run forge:fuzz && npm run forge:fuzz:manager && npm run forge:invariant:prime && npm run forge:invariant:ghost && npm run forge:invariant:clock && npm run forge:soak",
    "forge:fuzz:ci": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=ci forge test --match-path \"forge-test/fuzz/*.t.sol\"",
    "forge:invariant:all": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=ci forge test --match-path \"forge-test/invariant/*.t.sol\"",
    "forge:replay:ghost": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=ci forge test --match-contract PrimeProtocolGhostInvariants -vvvv",
    "forge:replay:prime": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=ci forge test --match-contract PrimeProtocolInvariants -vvvv",
    "forge:fuzz:manager": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=ci forge test --match-contract PrimeManagerSettlementFuzz",
    "forge:invariant:clock": "PATH=\"$HOME/.foundry/bin:$PATH\" FOUNDRY_PROFILE=ci forge test --match-contract PrimePauseDeadlineInvariants",
    "test:prime:pr": "npm run forge:fuzz && npm run forge:invariant"
  },
  "dependencies": {
    "@openzeppelin/contracts": "4.9.6"
  },
  "devDependencies": {
    "@openzeppelin/test-helpers": "^0.5.16",
    "@playwright/test": "^1.49.1",
    "@truffle/hdwallet-provider": "^2.1.15",
    "dotenv": "^16.6.1",
    "ganache": "^7.9.2",
    "keccak256": "^1.0.6",
    "merkletreejs": "^0.6.0",
    "solhint": "^5.0.3",
    "truffle": "^5.11.5"
  }
}
